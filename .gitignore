# Testing and Development
# ============================================================================

# Test outputs
test_results/
test_reports/
.test_cache/

# Sample data for testing (keep examples)
tests/fixtures/*.db
tests/fixtures/*.sqlite

# Temporary files
*.tmp
*.temp
*.bak
*.backup
*~
Attack Path Explorer + Predictive Vulnerability.txt
chat.txt
plan.txt

