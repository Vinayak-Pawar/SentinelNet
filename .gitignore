# IDE and Editor Specific (macOS focused)
# ============================================================================

# Cursor/VS Code settings (if you want personal settings to stay local)
# .vscode/settings.json
# .cursor/settings.json

# PyCharm
.idea/
*.iml

# Vim
*.swp
*.swo
*~

# Emacs
\#*\#
.\#*

# Sublime Text
*.sublime-project
*.sublime-workspace

# ============================================================================
# Docker and Containers
# ============================================================================

# Docker volumes and data
docker/data/
docker/volumes/

# Docker compose overrides (keep example)
docker-compose.override.yml
!docker-compose.override.yml.example

# ============================================================================
# Cloud and Infrastructure
# ============================================================================

# Terraform state files
*.tfstate
*.tfstate.*
.terraform/
.terraform.lock.hcl

# Kubernetes local config
*.kubeconfig
kubeconfig-*.yaml

# Ansible
*.retry

# ============================================================================
# Security and Sensitive Data
# ============================================================================

# Private keys and certificates
*.key
*.pem
*.crt
*.cer
*.p12
*.pfx

# SSH keys
id_rsa
id_rsa.pub
id_ed25519
id_ed25519.pub

# GPG keys
*.gpg
*.asc

# Encrypted files (keep encrypted versions if needed)
# *.enc

# ============================================================================
# MacOS Specific (Apple Silicon optimizations)
# ============================================================================

# MacOS system files
.DS_Store
.AppleDouble
.LSOverride
Icon

# Thumbnails
._*

# Files that might appear in the root of a volume
.DocumentRevisions-V100
.fseventsd
.Spotlight-V100
.TemporaryItems
.Trashes
.VolumeIcon.icns
.com.apple.timemachine.donotpresent

# Directories potentially created on remote AFP share
.AppleDB
.AppleDesktop
Network Trash Folder
Temporary Items
.apdisk

# ============================================================================
# Performance and Profiling
# ============================================================================

# Profiling data
*.prof
*.pstats
profile_*

# Memory dumps
*.hprof
*.dump

